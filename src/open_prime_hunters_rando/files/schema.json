{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "configuration_id": {
            "type": "integer",
            "default": 0,
            "description": "Identifier of the seed. Used for calculating RNG."
        },
        "starting_items": {
            "type": "object",
            "properties": {
                "weapons": {
                    "type": "object",
                    "description": "Determines what weapons to start with. Power Beam currently cannot be shuffled, so it is always starting.",
                    "properties": {
                        "battlehammer": {
                            "type": "boolean"
                        },
                        "imperialist": {
                            "type": "boolean"
                        },
                        "judicator": {
                            "type": "boolean"
                        },
                        "magmaul": {
                            "type": "boolean"
                        },
                        "missile_launcher": {
                            "type": "boolean"
                        },
                        "shock_coil": {
                            "type": "boolean"
                        },
                        "volt_driver": {
                            "type": "boolean"
                        }
                    },
                    "default": {
                        "battlehammer": false,
                        "missile_launcher": false,
                        "imperialist": false,
                        "judicator": false,
                        "magmaul": false,
                        "shock_coil": false,
                        "volt_driver": false
                    }
                },
                "missiles": {
                    "type": "integer",
                    "description": "The number of missiles to start with.",
                    "default": 5,
                    "minimum": 0,
                    "maximum": 102,
                    "if": {
                        "exclusiveMinimum": 25
                    },
                    "then": {
                        "multipleOf": 2
                    }
                },
                "ammo": {
                    "type": "integer",
                    "description": "The amount of UA to start with.",
                    "default": 40,
                    "minimum": 0,
                    "maximum": 102,
                    "if": {
                        "exclusiveMinimum": 25
                    },
                    "then": {
                        "multipleOf": 2
                    }
                },
                "energy": {
                    "type": "integer",
                    "description": "The amount of energy to start with.",
                    "default": 99,
                    "minimum": 1,
                    "maximum": 1299
                },
                "artifacts": {
                    "type": "object",
                    "description": "The amount of Artifacts to start with for each Boss Portal.",
                    "properties": {
                        "alinos_1": {
                            "type": "string"
                        },
                        "alinos_2": {
                            "type": "string"
                        },
                        "celestial_archives_1": {
                            "type": "string"
                        },
                        "celestial_archives_2": {
                            "type": "string"
                        },
                        "vesper_defense_outpost_1": {
                            "type": "string"
                        },
                        "vesper_defense_outpost_2": {
                            "type": "string"
                        },
                        "arcterra_1": {
                            "type": "string"
                        },
                        "arcterra_2": {
                            "type": "string"
                        }
                    },
                    "default": {
                        "alinos_1": "000",
                        "alinos_2": "000",
                        "celestial_archives_1": "000",
                        "celestial_archives_2": "000",
                        "vesper_defense_outpost_1": "000",
                        "vesper_defense_outpost_2": "000",
                        "arcterra_1": "000",
                        "arcterra_2": "000"
                    }
                },
                "octoliths": {
                    "type": "string",
                    "description": "Bitfield that determines what Octoliths to start with in descending order, 8-1.\nLeft to Right: Arcterra 2-1, VDO 2-1, Alinos 2-1, Celestial Archives 2-1",
                    "minLength": 8,
                    "default": "00000000"
                }
            },
            "required": [
                "weapons",
                "missiles"
            ]
        },
        "areas": {
            "type": "object",
            "properties": {
                "Celestial Archives": {
                    "$ref": "#/$defs/area"
                },
                "Alinos": {
                    "$ref": "#/$defs/area"
                },
                "Arcterra": {
                    "$ref": "#/$defs/area"
                },
                "Vesper Defense Outpost": {
                    "$ref": "#/$defs/area"
                },
                "Oubliette": {
                    "$ref": "#/$defs/area"
                }
            },
            "default": {},
            "additionalProperties": false
        },
        "ammo_sizes": {
            "type": "object",
            "description": "Configure the amount of ammo given by different sources.",
            "properties": {
                "missile_launcher": {
                    "type": "integer",
                    "default": 5,
                    "minimum": 0,
                    "maximum": 255
                },
                "missile_expansion": {
                    "type": "integer",
                    "default": 10,
                    "minimum": 0,
                    "maximum": 102,
                    "if": {
                        "exclusiveMinimum": 25
                    },
                    "then": {
                        "multipleOf": 2
                    }
                },
                "ua_expansion": {
                    "type": "integer",
                    "default": 30,
                    "minimum": 0,
                    "maximum": 102,
                    "if": {
                        "exclusiveMinimum": 25
                    },
                    "then": {
                        "multipleOf": 2
                    }
                }
            },
            "default": {}
        },
        "game_patches": {
            "type": "object",
            "properties": {
                "shuffle_hunter_colors": {
                    "type": "boolean",
                    "description": "Changes the colors of the hunters.",
                    "default": false
                },
                "shuffle_hunter_ids": {
                    "type": "boolean",
                    "description": "Changes the hunter spawns to be a different hunter.",
                    "default": false
                },
                "unlock_planets": {
                    "type": "object",
                    "description": "Choose which planets are unlocked from the start.",
                    "properties": {
                        "Alinos": {
                            "type": "boolean"
                        },
                        "Arcterra": {
                            "type": "boolean"
                        },
                        "Vesper Defense Outpost": {
                            "type": "boolean"
                        }
                    },
                    "default": {
                        "Alinos": true,
                        "Arcterra": true,
                        "Vesper Defense Outpost": true
                    }
                }
            },
            "default": {}
        },
        "text_patches": {
            "type": "object",
            "properties": {
                "frontend": {
                    "type": "object",
                    "description": "Modify the text of an entry in a frontend text file.",
                    "patternProperties": {
                        ".*": {
                            "type": "string"
                        }
                    }
                },
                "string_tables": {
                    "type": "object",
                    "properties": {
                        "scan_log": {
                            "type": "object",
                            "description": "Modify the text of an entry in the ScanLog.",
                            "patternProperties": {
                                ".*": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "default": {}
    },
    "required": [
        "starting_items",
        "areas"
    ],
    "$defs": {
        "area": {
            "type": "object",
            "properties": {
                "levels": {
                    "type": "object",
                    "patternProperties": {
                        ".*": {
                            "$ref": "#/$defs/level"
                        }
                    }
                }
            },
            "required": [
                "levels"
            ],
            "additionalProperties": false
        },
        "level": {
            "type": "object",
            "properties": {
                "pickups": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "entity_id": {
                                "type": "integer",
                                "description": "The id of the entity."
                            },
                            "entity_type": {
                                "type": "integer",
                                "enum": [
                                    4,
                                    17
                                ],
                                "description": "The entity type of the entity.\nItemSpawn: 4, Artifact: 17"
                            }
                        },
                        "required": [
                            "entity_id",
                            "entity_type"
                        ],
                        "if": {
                            "properties": {
                                "entity_type": {
                                    "const": 4
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "item_type": {
                                    "type": "integer",
                                    "description": "The item type to change the entity into.",
                                    "minimum": 0,
                                    "maximum": 22
                                }
                            },
                            "required": [
                                "item_type"
                            ],
                            "if": {
                                "properties": {
                                    "item_type": {
                                        "const": 19
                                    }
                                }
                            },
                            "then": {
                                "properties": {
                                    "state_bit": {
                                        "type": "integer",
                                        "description": "The state bit to activate when picked up.",
                                        "minimum": 0,
                                        "maximum": 63
                                    }
                                },
                                "required": [
                                    "state_bit"
                                ]
                            }
                        },
                        "else": {
                            "properties": {
                                "model_id": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "maximum": 8,
                                    "description": "The id of the model to use for the artifact."
                                },
                                "artifact_id": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "maximum": 7,
                                    "description": "The id of the artifact."
                                }
                            },
                            "required": [
                                "model_id",
                                "artifact_id"
                            ]
                        }
                    },
                    "default": []
                },
                "force_fields": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "entity_id": {
                                "type": "integer",
                                "description": "The id of the entity."
                            },
                            "type": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 9,
                                "description": "The type of force field. Sealed force fields can only be unlocked remotely.\nPower Beam, Volt Driver, Missile, Battlehammer, Imperialist, Judicator, Magmaul, Shock Coil, Omega Cannon, Sealed."
                            }
                        }
                    },
                    "required": [
                        "entity_id",
                        "weapon_type"
                    ],
                    "default": []
                },
                "portals": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "entity_id": {
                                "type": "integer",
                                "description": "The id of the entity."
                            },
                            "target_index": {
                                "type": "integer",
                                "description": "The load index of the target portal."
                            },
                            "active": {
                                "type": "boolean",
                                "description": "Determines if the portal is active by default."
                            },
                            "entity_file_name": {
                                "type": "string",
                                "description": "The entity file of the target portal."
                            }
                        }
                    },
                    "required": [
                        "entity_id",
                        "target_index",
                        "entity_file_name"
                    ],
                    "default": []
                },
                "doors": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "entity_id": {
                                "type": "integer",
                                "description": "The id of the entity."
                            },
                            "weapon_type": {
                                "type": "integer",
                                "description": "The weakness of door. Sealed doors can only be unlocked remotely.\nPower Beam, Volt Driver, Missile, Battlehammer, Imperialist, Judicator, Magmaul, Shock Coil, Omega Cannon, Sealed."
                            },
                            "locked": {
                                "type": "boolean",
                                "description": "Change if the door is locked or not. Must be set to True in order for the modified weakness to be active in game."
                            }
                        }
                    },
                    "required": [
                        "entity_id",
                        "weapon_type"
                    ],
                    "default": []
                }
            }
        }
    }
}